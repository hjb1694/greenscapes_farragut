{% extends './partials/page.base.twig' %}
{% block head %}
    {% from './partials/head.macro.twig' import head_macro %}
    {{ head_macro('Greenscapes Outdoor Living - Contact Us', '') }}
{% endblock head %}
{% block body %}
<section class="contact-heading">
    <h2>Contact Us</h2>
</section>
<section class="contact-area">
    <div class="narrow-container">
        <form>
            <div class="form-group">
                <div class="text-field">
                    <label class="text-field__label">First Name</label>
                    <input id="first-name" class="text-field__input" type="text" />
                </div>
            </div>
            <div class="form-group">
                <div class="text-field">
                    <label class="text-field__label">Last Name</label>
                    <input id="last-name" class="text-field__input" type="text" />
                </div>
            </div>
            <div class="form-group">
                <div class="text-field">
                    <label class="text-field__label">Email</label>
                    <input id="email" class="text-field__input" type="email" />
                </div>
            </div>
            <div class="form-group">
                <div class="text-field">
                    <label class="text-field__label">Phone [Optional]</label>
                    <input id="phone" class="text-field__input" type="tel" inputmode="numeric" placeholder="(XXX) XXX-XXXX" />
                </div>
            </div>
            <div class="form-group text-option">
                <label class="checkbox-field">
                    <input type="checkbox" id="can-text" class="checkbox-field__cb-input" />
                    <div class="checkbox-field__box"></div>
                    <span class="checkbox-field__label-text">Greenscapes may communicate via text message at this number (standard messaging data rates may apply) [optional]</span>
                </label>
            </div>
            <div class="form-group">
                <div class="text-field">
                    <label class="text-field__label">Message</label>
                    <textarea class="text-field__textarea"></textarea>
                </div>
            </div>
            <button class="subbut">
                <span>submit</span>
                <img src="/public/icons/send_icon.svg" alt="send icon" />
            </button>
        </form>
    </div>
</section>
{% endblock body %}
{% block scripts %}
<script src="https://unpkg.com/imask@7.6.1/dist/imask.js"></script>
<script src="/public/js/uikit.min.js"></script>
<script>
    const phoneInput = document.querySelector('#phone');
    const textOption = document.querySelector('.text-option');
    const textOptionCb = document.querySelector('#can-text');

    const phoneMaskOptions = {
        mask: '(000) 000-0000'
    }

    IMask(phoneInput, phoneMaskOptions);

    phoneInput.addEventListener('input', evt => {
        if(/^\([0-9]{3}\) [0-9]{3}\-[0-9]{4}$/.test(evt.target.value)){
            textOption.classList.add('show');
        }else{
            textOptionCb.checked = false;
            textOption.classList.remove('show');
        }
    });
</script>
{% endblock scripts %}